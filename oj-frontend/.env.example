# ============================================
# Geek OJ 前端环境变量配置范例
# 将本文件复制为 .env 并修改实际值
# ============================================

# FastAPI 网关地址（提交代码 + WebSocket）
VITE_API_BASE_URL=http://127.0.0.1:8080

# Django 后端地址（登录 + 题库 + 监控大盘）
VITE_DJANGO_BASE_URL=http://127.0.0.1:8000

# ============================================
# 生产环境示例：
# VITE_API_BASE_URL=https://api.geekoj.example.com
# VITE_DJANGO_BASE_URL=https://admin.geekoj.example.com
# ============================================
