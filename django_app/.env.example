# ============================================
# Geek OJ Django 后端环境变量配置范例
# 将本文件复制为 .env 并修改实际值
# 在 Docker 中通过 docker-compose environment: 注入
# ============================================

# Django 核心安全
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=geekoj.example.com,www.geekoj.example.com

# MySQL 数据库
MYSQL_ROOT_PASSWORD=change-me-to-a-strong-password
MYSQL_HOST=mysql_db
MYSQL_PORT=3306
MYSQL_REPLICA_HOST=mysql_db
MYSQL_REPLICA_PORT=3306

# CORS 允许的域名（逗号分隔）
CORS_ALLOWED_ORIGINS=https://geekoj.example.com,https://admin.geekoj.example.com

# JWT 签名密钥（必须与 FastAPI 中的一致）
JWT_SECRET_KEY=change-me-to-another-random-50-char-string
